; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="RTS Lobby"
config/features=PackedStringArray("4.7", "GL Compatibility")
run/max_fps=120
config/icon="res://assets/placeholder/icon.svg"

[autoload]

LocalPlayerData="*uid://4cebbyiw6dgv"
ReplayManager="*uid://c52xk0rxkg112"
DebugGlobal="*uid://cvjfea0q8veg8"
Lobby="*uid://dcc12p4tfdrvs"

[debug]

gdscript/warnings/untyped_declaration=2
gdscript/warnings/inferred_declaration=2
gdscript/warnings/unsafe_property_access=1
gdscript/warnings/unsafe_method_access=1
gdscript/warnings/return_value_discarded=1

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[editor_plugins]

enabled=PackedStringArray("res://addons/MarchingSquaresTerrain/plugin.cfg")

[file_customization]

folder_colors={
"res://TODO/": "purple",
"res://_deprecated/": "gray",
"res://addons/": "gray",
"res://analytics/": "pink",
"res://assets/": "orange",
"res://functional/": "blue",
"res://resources/": "yellow",
"res://scenes/": "green",
"res://scripts/": "teal"
}

[global_group]

Main="Used to get Main"
InputController="Accessed by GUI to update information"
Game="used by spawning units to request unit spawn"
CommandController="3d input controller"
Entity="All possible entities, but this includes resource nodes?"
Unit="Only Units in this group, excludes buildings"
Building="Excludes Units"
EntityHolder="EntityHolder"
Resource="In Game Resources"
PlayerDataManager=""
SyncComponent=""

[gui]

theme/default_font_multichannel_signed_distance_field=true

