3d_physics/layer_2="InteractLayer"
3d_physics/layer_3="Units"
3d_physics/layer_4="Buildings"
3d_physics/layer_5="SelectLayer"
3d_physics/layer_6="AggroLayer"
3d_physics/layer_13="building_grid"
3d_physics/layer_32="NavBakeLayer"

[physics]

3d/physics_engine="Jolt Physics"

